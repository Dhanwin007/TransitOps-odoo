generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id       Int    @id @default(autoincrement())
  roleName String @unique @map("role_name")
  users    User[]

  @@map("roles")
}

model User {
  id            Int             @id @default(autoincrement())
  name          String
  email         String          @unique
  passwordHash  String          @map("password_hash")
  roleId        Int             @map("role_id")
  isActive      Boolean         @default(true) @map("is_active")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  statusChanges StatusHistory[]
  createdTrips  Trip[]
  role          Role            @relation(fields: [roleId], references: [id])

  @@map("users")
}

model Vehicle {
  id              Int              @id @default(autoincrement())
  registrationNo  String           @unique @map("registration_no")
  vehicleName     String           @map("vehicle_name")
  model           String
  vehicleType     String           @map("vehicle_type")
  maxCapacityKg   Decimal          @map("max_capacity_kg") @db.Decimal(10, 2)
  odometer        Decimal          @db.Decimal(12, 2)
  acquisitionCost Decimal          @map("acquisition_cost") @db.Decimal(12, 2)
  purchaseDate    DateTime         @map("purchase_date") @db.Date
  status          String           @default("AVAILABLE")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  expenses        Expense[]
  fuelLogs        FuelLog[]
  maintenanceLogs MaintenanceLog[]
  trips           Trip[]

  @@map("vehicles")
}

model Driver {
  id              Int      @id @default(autoincrement())
  name            String
  licenseNo       String   @unique @map("license_no")
  licenseCategory String   @map("license_category")
  licenseExpiry   DateTime @map("license_expiry") @db.Date
  phone           String
  safetyScore     Decimal  @map("safety_score") @db.Decimal(5, 2)
  status          String   @default("AVAILABLE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  trips           Trip[]

  @@map("drivers")
}

model Trip {
  id              Int       @id @default(autoincrement())
  tripNo          String    @unique @map("trip_no")
  vehicleId       Int       @map("vehicle_id")
  driverId        Int       @map("driver_id")
  source          String
  destination     String
  cargoWeight     Decimal   @map("cargo_weight") @db.Decimal(10, 2)
  plannedDistance Decimal   @map("planned_distance") @db.Decimal(10, 2)
  actualDistance  Decimal?  @map("actual_distance") @db.Decimal(10, 2)
  fuelUsed        Decimal?  @map("fuel_used") @db.Decimal(10, 2)
  estimatedTime   String?   @map("estimated_time")
  startTime       DateTime? @map("start_time")
  endTime         DateTime? @map("end_time")
  status          String    @default("DRAFT")
  createdBy       Int       @map("created_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  expenses        Expense[]
  fuelLogs        FuelLog[]
  creator         User      @relation(fields: [createdBy], references: [id])
  driver          Driver    @relation(fields: [driverId], references: [id])
  vehicle         Vehicle   @relation(fields: [vehicleId], references: [id])

  @@map("trips")
}

model MaintenanceLog {
  id          Int       @id @default(autoincrement())
  vehicleId   Int       @map("vehicle_id")
  serviceType String    @map("service_type")
  description String?
  cost        Decimal   @db.Decimal(12, 2)
  startDate   DateTime  @map("start_date") @db.Date
  endDate     DateTime? @map("end_date") @db.Date
  status      String    @default("ACTIVE")
  createdAt   DateTime  @default(now()) @map("created_at")
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id])

  @@map("maintenance_logs")
}

model FuelLog {
  id          Int      @id @default(autoincrement())
  vehicleId   Int      @map("vehicle_id")
  tripId      Int?     @map("trip_id")
  litres      Decimal  @db.Decimal(10, 2)
  cost        Decimal  @db.Decimal(12, 2)
  fuelStation String?  @map("fuel_station")
  odometer    Decimal  @db.Decimal(12, 2)
  logDate     DateTime @map("log_date") @db.Date
  createdAt   DateTime @default(now()) @map("created_at")
  trip        Trip?    @relation(fields: [tripId], references: [id])
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])

  @@map("fuel_logs")
}

model Expense {
  id          Int      @id @default(autoincrement())
  tripId      Int?     @map("trip_id")
  vehicleId   Int      @map("vehicle_id")
  expenseType String   @map("expense_type")
  amount      Decimal  @db.Decimal(12, 2)
  description String?
  expenseDate DateTime @map("expense_date") @db.Date
  createdAt   DateTime @default(now()) @map("created_at")
  trip        Trip?    @relation(fields: [tripId], references: [id])
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])

  @@map("expenses")
}

model StatusHistory {
  id         Int      @id @default(autoincrement())
  entityType String   @map("entity_type")
  entityId   Int      @map("entity_id")
  oldStatus  String   @map("old_status")
  newStatus  String   @map("new_status")
  changedBy  Int      @map("changed_by")
  remarks    String?
  changedAt  DateTime @default(now()) @map("changed_at")
  user       User     @relation(fields: [changedBy], references: [id])

  @@index([entityType, entityId])
  @@map("status_history")
}

model Setting {
  id           Int      @id @default(autoincrement())
  depotName    String   @map("depot_name")
  currency     String   @default("INR")
  distanceUnit String   @default("km") @map("distance_unit")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
